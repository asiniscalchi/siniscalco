# Server
PORT=3000
DB_PATH=data/app.db

# FX rates (Frankfurter, no API key required)
FX_REFRESH_BASE_URL=https://api.frankfurter.dev/v1

# Crypto prices (CoinGecko, no API key required)
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# Stock prices — set one or more provider API keys to enable stock price refresh.
# Provider priority: Twelve Data > Finnhub > Alpha Vantage > Polygon > FMP > EODHD > Tiingo > Marketstack.

# Twelve Data (https://twelvedata.com)
TWELVE_DATA_API_KEY=
TWELVE_DATA_BASE_URL=https://api.twelvedata.com

# Finnhub (https://finnhub.io)
FINNHUB_API_KEY=
FINNHUB_BASE_URL=https://finnhub.io

# Alpha Vantage (https://www.alphavantage.co)
ALPHA_VANTAGE_API_KEY=
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co

# Polygon.io (https://polygon.io)
POLYGON_API_KEY=
POLYGON_BASE_URL=https://api.polygon.io

# Financial Modeling Prep (https://financialmodelingprep.com)
FMP_API_KEY=
FMP_BASE_URL=https://financialmodelingprep.com

# EODHD (https://eodhd.com) — use SYMBOL.EXCHANGE format in quote_symbol (e.g. AAPL.US)
EODHD_API_KEY=
EODHD_BASE_URL=https://eodhd.com

# Tiingo (https://tiingo.com)
TIINGO_API_KEY=
TIINGO_BASE_URL=https://api.tiingo.com

# Marketstack (https://marketstack.com)
MARKETSTACK_API_KEY=
MARKETSTACK_BASE_URL=https://api.marketstack.com
